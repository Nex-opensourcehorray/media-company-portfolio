# Terraform working directories
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Terraform plans
*.tfplan
*.plan

# Variable files may contain sensitive values
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform CLI configuration
.terraformrc
terraform.rc

# Lock files are intentionally committed for root configurations.
# Override files
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Local environment files
.env
.env.*
!.env.example

# IDE and operating-system files
.vscode/
.idea/
.DS_Store
Thumbs.db
